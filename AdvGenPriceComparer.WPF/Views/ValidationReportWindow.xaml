<Window x:Class="AdvGenPriceComparer.WPF.Views.ValidationReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:AdvGenPriceComparer.Core.Models;assembly=AdvGenPriceComparer.Core"
        xmlns:coreModels="clr-namespace:AdvGenPriceComparer.Core.Models;assembly=AdvGenPriceComparer.Core"
        xmlns:local="clr-namespace:AdvGenPriceComparer.WPF.Converters"
        mc:Ignorable="d"
        Title="Data Validation Report" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterOwner"
        MinWidth="800" MinHeight="500">

    <Window.Resources>
        <!-- Severity Color Converters -->
        <SolidColorBrush x:Key="ErrorBrush" Color="#DC3545"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#FFC107"/>
        <SolidColorBrush x:Key="InfoBrush" Color="#17A2B8"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#28A745"/>
        
        <!-- Severity to Color Converter -->
        <local:ValidationSeverityToBrushConverter x:Key="SeverityToBrushConverter"/>
        <local:ValidationSeverityToIconConverter x:Key="SeverityToIconConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource SystemAccentColorBrush}" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Data Validation Report" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding SourceName, StringFormat='Source: {0}'}" 
                               Foreground="White" Opacity="0.9" Margin="0,3,0,0"/>
                </StackPanel>
                
                <Border Grid.Column="1" Background="White" CornerRadius="4" Padding="15,8" Margin="10,0,0,0">
                    <TextBlock Text="{Binding StatusText}" FontSize="16" FontWeight="Bold" 
                               Foreground="{DynamicResource SystemAccentColorBrush}"/>
                </Border>
            </Grid>
        </Border>

        <!-- Summary Cards -->
        <Grid Grid.Row="1" Margin="15,15,15,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Items -->
            <Border Grid.Column="0" Background="#E3F2FD" CornerRadius="6" Padding="15,10" Margin="0,0,5,0">
                <StackPanel>
                    <TextBlock Text="Total Items" FontSize="11" Foreground="#666"/>
                    <TextBlock Text="{Binding TotalItems}" FontSize="24" FontWeight="Bold" Foreground="#1976D2"/>
                </StackPanel>
            </Border>

            <!-- Valid Items -->
            <Border Grid.Column="1" Background="#E8F5E9" CornerRadius="6" Padding="15,10" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="Valid" FontSize="11" Foreground="#666"/>
                    <TextBlock Text="{Binding ValidItems}" FontSize="24" FontWeight="Bold" Foreground="#388E3C"/>
                </StackPanel>
            </Border>

            <!-- Warnings -->
            <Border Grid.Column="2" Background="#FFF8E1" CornerRadius="6" Padding="15,10" Margin="5,0"
                    Visibility="{Binding HasWarnings, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Warnings" FontSize="11" Foreground="#666"/>
                    <TextBlock Text="{Binding TotalWarnings}" FontSize="24" FontWeight="Bold" Foreground="#F57C00"/>
                </StackPanel>
            </Border>

            <!-- Errors -->
            <Border Grid.Column="3" Background="#FFEBEE" CornerRadius="6" Padding="15,10" Margin="5,0"
                    Visibility="{Binding HasErrors, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Errors" FontSize="11" Foreground="#666"/>
                    <TextBlock Text="{Binding TotalErrors}" FontSize="24" FontWeight="Bold" Foreground="#D32F2F"/>
                </StackPanel>
            </Border>

            <!-- Success Rate -->
            <Border Grid.Column="4" Background="#F3E5F5" CornerRadius="6" Padding="15,10" Margin="5,0,0,0">
                <StackPanel>
                    <TextBlock Text="Success Rate" FontSize="11" Foreground="#666"/>
                    <TextBlock Text="{Binding SuccessRate, StringFormat='{}{0:F1}%'}" 
                               FontSize="24" FontWeight="Bold" Foreground="#7B1FA2"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Tabbed Content -->
        <TabControl Grid.Row="2" Margin="15,5,15,10" SelectedIndex="{Binding SelectedTabIndex}">
            
            <!-- Validation Entries Tab -->
            <TabItem Header="Validation Entries">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Filters -->
                    <Border Grid.Row="0" Background="{DynamicResource SystemAltMediumColor}" Padding="10" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Severity:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <ComboBox Width="120" SelectedItem="{Binding SelectedSeverity}" Margin="0,0,15,0">
                                <ComboBox.Items>
                                    <coreModels:ValidationSeverity>Info</coreModels:ValidationSeverity>
                                    <coreModels:ValidationSeverity>Warning</coreModels:ValidationSeverity>
                                    <coreModels:ValidationSeverity>Error</coreModels:ValidationSeverity>
                                    <coreModels:ValidationSeverity>Critical</coreModels:ValidationSeverity>
                                </ComboBox.Items>
                            </ComboBox>

                            <TextBlock Text="Type:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <ComboBox Width="120" SelectedItem="{Binding SelectedEntryType}" Margin="0,0,15,0">
                                <ComboBox.Items>
                                    <coreModels:ValidationEntryType>Store</coreModels:ValidationEntryType>
                                    <coreModels:ValidationEntryType>Product</coreModels:ValidationEntryType>
                                    <coreModels:ValidationEntryType>PriceRecord</coreModels:ValidationEntryType>
                                    <coreModels:ValidationEntryType>Manifest</coreModels:ValidationEntryType>
                                    <coreModels:ValidationEntryType>Schema</coreModels:ValidationEntryType>
                                    <coreModels:ValidationEntryType>Checksum</coreModels:ValidationEntryType>
                                </ComboBox.Items>
                            </ComboBox>

                            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox Width="180" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                     Margin="0,0,15,0"/>

                            <CheckBox Content="Show only duplicates" 
                                      IsChecked="{Binding ShowOnlyDuplicates}"
                                      VerticalAlignment="Center" Margin="0,0,15,0"/>

                            <Button Content="Clear Filters" Command="{Binding ClearFiltersCommand}"
                                    Padding="15,3"/>
                        </StackPanel>
                    </Border>

                    <!-- Entries DataGrid -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredEntries}" 
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              SelectedItem="{Binding SelectedEntry}"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Severity" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" 
                                                Value="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Type" Binding="{Binding EntryType}" Width="100"/>
                            <DataGridTextColumn Header="Entity" Binding="{Binding EntityName}" Width="150"/>
                            <DataGridTextColumn Header="Field" Binding="{Binding FieldName}" Width="120"/>
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding CurrentValue}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Duplicates Tab -->
            <TabItem Header="Duplicates" Visibility="{Binding HasDuplicates, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <TextBlock Text="Duplicate Detection Results" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    
                    <ItemsControl ItemsSource="{Binding DuplicateGroups}" Margin="0,30,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:DuplicateGroup">
                                <Border Background="{DynamicResource SystemAltLowColor}" 
                                        CornerRadius="4" Padding="10" Margin="0,5">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Grid.Row="0" Text="{Binding DuplicateKey, StringFormat='Duplicate Key: {0}'}" 
                                                   FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        
                                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="models:DuplicateItem">
                                                    <Grid Margin="10,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="150"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding EntityName}"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Source}"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Timestamp, StringFormat='{}{0:g}'}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </TabItem>

            <!-- Summary Tab -->
            <TabItem Header="Summary">
                <ScrollViewer>
                    <StackPanel Margin="20">
                        <TextBlock Text="Validation Summary" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                <TextBlock Text="Overall Statistics" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding SummaryText}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SuccessRate, StringFormat='Success Rate: {0:F1}%'}" Margin="0,5"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Report Details" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding Report.ReportType, StringFormat='Type: {0}'}"/>
                                <TextBlock Text="{Binding Report.GeneratedAt, StringFormat='Generated: {0:g}'}" Margin="0,5"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Footer Buttons -->
        <Border Grid.Row="3" Background="{DynamicResource SystemAltMediumColor}" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Export as:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Content="JSON" Command="{Binding ExportReportCommand}" 
                            CommandParameter="{x:Static models:ValidationReportFormat.Json}"
                            Padding="15,5" Margin="0,0,5,0"/>
                    <Button Content="Markdown" Command="{Binding ExportReportCommand}"
                            CommandParameter="{x:Static models:ValidationReportFormat.Markdown}"
                            Padding="15,5" Margin="0,0,5,0"/>
                    <Button Content="CSV" Command="{Binding ExportReportCommand}"
                            CommandParameter="{x:Static models:ValidationReportFormat.Csv}"
                            Padding="15,5}"/>
                </StackPanel>

                <Button Grid.Column="2" Content="Close" Command="{Binding CloseCommand}"
                        Padding="25,8" IsDefault="True" IsCancel="True"/>
            </Grid>
        </Border>
    </Grid>
</Window>
