<Window x:Class="AdvGenPriceComparer.WPF.Views.CloudSyncStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Cloud Sync Status" Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        MinWidth="700" MinHeight="500">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
        <Style x:Key="StatusCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource SystemAccentColorBrush}" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="☁️ Cloud Sync" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Synchronize your data across devices"
                               Foreground="White" Opacity="0.9" Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LastSyncDisplay, StringFormat='Last sync: {0}'}" 
                               Foreground="White" FontSize="12" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding CurrentStatus}" 
                               Foreground="White" FontSize="12" HorizontalAlignment="Right" Opacity="0.8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Grid Grid.Row="1" Background="{DynamicResource SystemControlBackgroundAltMediumBrush}" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" VerticalAlignment="Center" 
                       FontWeight="SemiBold" Margin="0,0,15,0"/>

            <ProgressBar Grid.Column="1" Value="{Binding SyncProgress}" Maximum="100" 
                         Height="8" VerticalAlignment="Center" IsIndeterminate="{Binding IsBusy}"
                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <TextBlock Text="Queue: " VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SyncQueueCount}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBlock Text="Conflicts: " VerticalAlignment="Center"/>
                <TextBlock Text="{Binding PendingConflictsCount}" FontWeight="Bold" VerticalAlignment="Center"
                           Foreground="{Binding HasPendingConflicts, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Red}"/>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <TabControl Grid.Row="2" Margin="10">
            <TabItem Header="📊 Status">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <!-- Quick Stats -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource StatusCard}">
                                <StackPanel>
                                    <TextBlock Text="Status" FontSize="12" Opacity="0.7"/>
                                    <TextBlock Text="{Binding CurrentStatus}" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource StatusCard}">
                                <StackPanel>
                                    <TextBlock Text="Cloud Sync" FontSize="12" Opacity="0.7"/>
                                    <TextBlock Text="{Binding Settings.IsEnabled, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Enabled;Disabled}" 
                                               FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource StatusCard}">
                                <StackPanel>
                                    <TextBlock Text="Schedule" FontSize="12" Opacity="0.7"/>
                                    <TextBlock Text="{Binding Settings.ScheduleMode}" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Last Sync Result -->
                        <GroupBox Header="Last Synchronization" Margin="0,15,0,0">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Uploaded:" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LastSyncResult.ItemsUploaded, FallbackValue='0'}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Downloaded:" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LastSyncResult.ItemsDownloaded, FallbackValue='0'}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Conflicts:" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastSyncResult.ConflictsDetected, FallbackValue='0'}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Result:" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LastSyncResult.Message, FallbackValue='No sync performed yet'}" 
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </GroupBox>

                        <!-- Quick Actions -->
                        <GroupBox Header="Quick Actions" Margin="0,15,0,0">
                            <WrapPanel Margin="10">
                                <Button Content="🔄 Sync Now" AutomationProperties.Name="Sync Now" Style="{StaticResource ActionButton}"
                                        Command="{Binding SyncNowCommand}" IsEnabled="{Binding CanSync}"/>
                                <Button Content="📤 Export to Cloud" Style="{StaticResource ActionButton}" 
                                        Command="{Binding ExportCommand}" IsEnabled="{Binding CanSync}"/>
                                <Button Content="📥 Import from Cloud" Style="{StaticResource ActionButton}" 
                                        Command="{Binding ImportCommand}" IsEnabled="{Binding CanSync}"/>
                                <Button Content="🔌 Test Connection" Style="{StaticResource ActionButton}" 
                                        Command="{Binding TestConnectionCommand}" IsEnabled="{Binding CanSync}"/>
                            </WrapPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="⚙️ Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="General Settings">
                            <StackPanel Margin="10">
                                <CheckBox Content="Enable Cloud Sync" IsChecked="{Binding Settings.IsEnabled}" Margin="0,5"/>
                                <CheckBox Content="Sync on Startup" IsChecked="{Binding Settings.SyncOnStartup}" Margin="0,5"/>
                                <CheckBox Content="Sync on Shutdown" IsChecked="{Binding Settings.SyncOnShutdown}" Margin="0,5"/>
                                <CheckBox Content="Wi-Fi Only" IsChecked="{Binding Settings.WifiOnly}" Margin="0,5"/>
                                <CheckBox Content="Enable Compression" IsChecked="{Binding Settings.EnableCompression}" Margin="0,5"/>
                                <CheckBox Content="Enable Encryption" IsChecked="{Binding Settings.EnableEncryption}" Margin="0,5"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Server Settings" Margin="0,15,0,0">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Provider:" VerticalAlignment="Center" Margin="0,5"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" SelectedItem="{Binding Settings.ProviderType}" Margin="5">
                                    <ComboBox.Items>
                                        <core:CloudProviderType xmlns:core="clr-namespace:AdvGenPriceComparer.Core.Models;assembly=AdvGenPriceComparer.Core">AdvGenCloud</core:CloudProviderType>
                                        <core:CloudProviderType xmlns:core="clr-namespace:AdvGenPriceComparer.Core.Models;assembly=AdvGenPriceComparer.Core">CustomServer</core:CloudProviderType>
                                    </ComboBox.Items>
                                </ComboBox>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Server URL:" VerticalAlignment="Center" Margin="0,5"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Settings.ServerUrl}" Margin="5"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="API Key:" VerticalAlignment="Center" Margin="0,5"/>
                                <PasswordBox Grid.Row="2" Grid.Column="1" Margin="5" x:Name="ApiKeyBox"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Device ID:" VerticalAlignment="Center" Margin="0,5"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Settings.DeviceId}" Margin="5" IsReadOnly="True"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Sync Schedule" Margin="0,15,0,0">
                            <StackPanel Margin="10">
                                <TextBlock Text="Schedule Mode:" FontWeight="SemiBold"/>
                                <ComboBox SelectedItem="{Binding Settings.ScheduleMode}" Margin="0,5">
                                    <ComboBox.Items>
                                        <core:SyncScheduleMode xmlns:core="clr-namespace:AdvGenPriceComparer.Core.Models;assembly=AdvGenPriceComparer.Core">Manual</core:SyncScheduleMode>
                                        <core:SyncScheduleMode xmlns:core="clr-namespace:AdvGenPriceComparer.Core.Models;assembly=AdvGenPriceComparer.Core">OnChange</core:SyncScheduleMode>
                                        <core:SyncScheduleMode xmlns:core="clr-namespace:AdvGenPriceComparer.Core.Models;assembly=AdvGenPriceComparer.Core">Periodic</core:SyncScheduleMode>
                                    </ComboBox.Items>
                                </ComboBox>

                                <TextBlock Text="Auto Sync Interval (minutes):" FontWeight="SemiBold" Margin="0,10,0,0"/>
                                <Slider Value="{Binding Settings.AutoSyncIntervalMinutes}" Minimum="5" Maximum="1440" 
                                        TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,5"/>
                                <TextBlock Text="{Binding Settings.AutoSyncIntervalMinutes, StringFormat='{}{0} minutes'}" 
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Conflict Resolution" Margin="0,15,0,0">
                            <StackPanel Margin="10">
                                <TextBlock Text="Default Strategy:" FontWeight="SemiBold"/>
                                <ComboBox SelectedItem="{Binding Settings.DefaultConflictResolution}" Margin="0,5">
                                    <ComboBox.Items>
                                        <core:ConflictResolutionStrategy xmlns:core="clr-namespace:AdvGenPriceComparer.Core.Models;assembly=AdvGenPriceComparer.Core">ServerWins</core:ConflictResolutionStrategy>
                                        <core:ConflictResolutionStrategy xmlns:core="clr-namespace:AdvGenPriceComparer.Core.Models;assembly=AdvGenPriceComparer.Core">ClientWins</core:ConflictResolutionStrategy>
                                        <core:ConflictResolutionStrategy xmlns:core="clr-namespace:AdvGenPriceComparer.Core.Models;assembly=AdvGenPriceComparer.Core">LastWriteWins</core:ConflictResolutionStrategy>
                                        <core:ConflictResolutionStrategy xmlns:core="clr-namespace:AdvGenPriceComparer.Core.Models;assembly=AdvGenPriceComparer.Core">Manual</core:ConflictResolutionStrategy>
                                    </ComboBox.Items>
                                </ComboBox>
                            </StackPanel>
                        </GroupBox>

                        <Button Content="Save Settings" Command="{Binding SaveSettingsCommand}" 
                                HorizontalAlignment="Right" Padding="20,10" Margin="0,15,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="⚠️ Conflicts">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Pending Conflicts: " FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding PendingConflictsCount}" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="Resolve All" Command="{Binding ResolveAllConflictsCommand}" 
                                Margin="20,0,0,0" Padding="15,5" IsEnabled="{Binding HasPendingConflicts}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding PendingConflicts}" AutoGenerateColumns="False" 
                              IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Entity Type" Binding="{Binding EntityType}" Width="100"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding EntityName}" Width="*"/>
                            <DataGridTextColumn Header="Local Modified" Binding="{Binding LocalModifiedAt, StringFormat='g'}" Width="130"/>
                            <DataGridTextColumn Header="Server Modified" Binding="{Binding ServerModifiedAt, StringFormat='g'}" Width="130"/>
                            <DataGridTemplateColumn Header="Action" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Resolve" Command="{Binding DataContext.ResolveConflictCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}" Padding="10,3"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="1" Text="No pending conflicts" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding HasPendingConflicts, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverted}"/>
                </Grid>
            </TabItem>

            <TabItem Header="📋 Sync Queue">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Items in Queue: " FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SyncQueueCount}" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="Clear Queue" Command="{Binding ClearQueueCommand}" 
                                Margin="20,0,0,0" Padding="15,5"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding SyncQueueItems}" AutoGenerateColumns="False" 
                              IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Operation" Binding="{Binding Operation}" Width="100"/>
                            <DataGridTextColumn Header="Entity Type" Binding="{Binding EntityType}" Width="100"/>
                            <DataGridTextColumn Header="Entity ID" Binding="{Binding EntityId}" Width="200"/>
                            <DataGridTextColumn Header="Queued At" Binding="{Binding QueuedAt, StringFormat='g'}" Width="130"/>
                            <DataGridTextColumn Header="Retries" Binding="{Binding RetryCount}" Width="70"/>
                            <DataGridTextColumn Header="Next Retry" Binding="{Binding NextRetryAt, StringFormat='g'}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="1" Text="Sync queue is empty" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding SyncQueueCount, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="3" Background="{DynamicResource SystemControlBackgroundAltMediumBrush}" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Enable Auto Sync" Command="{Binding EnableAutoSyncCommand}" 
                        Padding="15,8" Margin="0,0,10,0" 
                        Visibility="{Binding Settings.ScheduleMode, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Manual}"/>
                <Button Content="Disable Auto Sync" Command="{Binding DisableAutoSyncCommand}" 
                        Padding="15,8" Margin="0,0,10,0"
                        Visibility="{Binding Settings.ScheduleMode, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Periodic}"/>
                <Button Content="Close" Click="CloseButton_Click" Padding="20,8"/>
            </StackPanel>
        </Border>

        <!-- Offline Warning -->
        <Border Grid.Row="4" Background="#FFF3CD" BorderBrush="#FFEAA7" BorderThickness="0,1,0,0" Padding="10"
                Visibility="{Binding CurrentStatus, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Offline}">
            <TextBlock Text="⚠️ Currently in offline mode. Changes will be queued and synchronized when connection is restored." 
                       Foreground="#856404" TextAlignment="Center"/>
        </Border>
    </Grid>
</Window>
