<Window x:Class="AdvGenPriceComparer.WPF.Views.IllusoryDiscountDetectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="750"
        Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="White"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#f8fafb" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1" Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Illusory Discount Detection" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="ML-powered detection of fake sales and genuine deals" 
                               FontSize="13" Foreground="#666" Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Close"
                        Click="CloseButton_Click"
                        Width="80"
                        Height="36"
                        Background="#111"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="14"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Control Panel -->
        <Border Grid.Row="1" Background="#f9f9f9" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Item Selection -->
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Select Product (Optional - scan all if not selected):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding Items}"
                                  SelectedItem="{Binding SelectedItem}"
                                  DisplayMemberPath="Name"
                                  Padding="10,8"
                                  FontSize="13"/>
                    </StackPanel>

                    <!-- Scan Selected Button -->
                    <Button Grid.Column="1"
                            Content="Scan Selected"
                            Command="{Binding ScanSelectedItemCommand}"
                            Width="120"
                            Height="40"
                            Background="#2563eb"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"
                            Margin="12,0,8,0"
                            VerticalAlignment="Bottom"/>

                    <!-- Scan All Button -->
                    <Button Grid.Column="2"
                            Content="Scan All Items"
                            Command="{Binding ScanAllItemsCommand}"
                            Width="120"
                            Height="40"
                            Background="#111"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"
                            Margin="0,0,8,0"
                            VerticalAlignment="Bottom"/>

                    <!-- Clear Button -->
                    <Button Grid.Column="3"
                            Content="Clear"
                            Command="{Binding ClearResultsCommand}"
                            Width="80"
                            Height="40"
                            Background="#dc2626"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"
                            VerticalAlignment="Bottom"/>
                </Grid>
                
                <!-- Loading Indicator -->
                <Grid Grid.Row="1" Margin="0,12,0,0" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar Grid.Column="0" Width="20" Height="20" Margin="0,0,10,0" 
                                 IsIndeterminate="True"/>
                    <TextBlock Grid.Column="1" Text="{Binding LoadingMessage}" VerticalAlignment="Center" FontSize="13"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Statistics Panel -->
        <Border Grid.Row="2" Background="White" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Items Scanned -->
                <Border Grid.Column="0" Background="#f8fafb" BorderBrush="#e2e8f0" BorderThickness="1" 
                        CornerRadius="4" Padding="16,12" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Items Scanned" FontSize="12" Foreground="#666"/>
                        <TextBlock Text="{Binding TotalItemsScanned}" FontSize="20" FontWeight="Bold" Foreground="#111"/>
                    </StackPanel>
                </Border>

                <!-- Illusory Discounts -->
                <Border Grid.Column="1" Background="#fef2f2" BorderBrush="#fecaca" BorderThickness="1" 
                        CornerRadius="4" Padding="16,12" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="Illusory Discounts" FontSize="12" Foreground="#dc2626"/>
                        <TextBlock Text="{Binding IllusoryDiscountsFound}" FontSize="20" FontWeight="Bold" Foreground="#dc2626"/>
                    </StackPanel>
                </Border>

                <!-- Genuine Deals -->
                <Border Grid.Column="2" Background="#f0fdf4" BorderBrush="#bbf7d0" BorderThickness="1" 
                        CornerRadius="4" Padding="16,12" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="Genuine Deals" FontSize="12" Foreground="#16a34a"/>
                        <TextBlock Text="{Binding GenuineDealsFound}" FontSize="20" FontWeight="Bold" Foreground="#16a34a"/>
                    </StackPanel>
                </Border>

                <!-- Avg Savings -->
                <Border Grid.Column="3" Background="#eff6ff" BorderBrush="#bfdbfe" BorderThickness="1" 
                        CornerRadius="4" Padding="16,12" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="Avg. Genuine Savings" FontSize="12" Foreground="#2563eb"/>
                        <TextBlock Text="{Binding AverageSavingsPercentage, StringFormat='{}{0:F1}%'}" FontSize="20" FontWeight="Bold" Foreground="#2563eb"/>
                    </StackPanel>
                </Border>

                <!-- Status -->
                <Border Grid.Column="4" Background="#f8fafb" BorderBrush="#e2e8f0" BorderThickness="1" 
                        CornerRadius="4" Padding="16,12" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Status" FontSize="12" Foreground="#666"/>
                        <TextBlock Text="{Binding ScanStatus}" FontSize="12" FontWeight="SemiBold" Foreground="#111" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Results Panel -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- No Results Message -->
                <Border Grid.Row="0" Background="#f9f9f9" BorderBrush="#e2e8f0" BorderThickness="1" 
                        CornerRadius="4" Padding="40" Margin="0,0,0,20"
                        Visibility="{Binding ShowNoResultsMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="No scan results yet" FontSize="16" FontWeight="SemiBold" 
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Select an item and click 'Scan Selected' or click 'Scan All Items' to detect illusory discounts" 
                                   FontSize="13" Foreground="#666" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Detected Discounts Section -->
                <Border Grid.Row="0" Background="White" BorderBrush="#e2e8f0" BorderThickness="1" 
                        CornerRadius="4" Padding="16" Margin="0,0,0,20"
                        Visibility="{Binding HasDetectedDiscounts, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Detected Discounts Analysis" FontSize="16" FontWeight="SemiBold"/>
                            <Button Grid.Column="1" Content="Export" Command="{Binding ExportResultsCommand}" 
                                    Padding="12,6" Background="#2563eb" Foreground="White" BorderThickness="0"/>
                        </Grid>
                        
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding DetectedDiscounts}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  Background="White"
                                  RowHeight="56"
                                  CanUserResizeRows="False"
                                  FontSize="13">
                            
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#f8fafb"/>
                                    <Setter Property="Foreground" Value="#666"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#e2e8f0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="12,0"/>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product" Binding="{Binding ItemName}" Width="200">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120"/>
                                <DataGridTextColumn Header="Store" Binding="{Binding StoreName}" Width="120"/>
                                <DataGridTextColumn Header="Current Price" Binding="{Binding CurrentPrice, StringFormat='{}{0:C2}'}" Width="100"/>
                                <DataGridTextColumn Header="Avg Price" Binding="{Binding AveragePrice, StringFormat='{}{0:C2}'}" Width="100"/>
                                <DataGridTextColumn Header="Savings" Binding="{Binding SavingsText}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#16a34a"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="Status" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding StatusColor}" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- All Anomalies Section -->
                <Border Grid.Row="1" Background="White" BorderBrush="#e2e8f0" BorderThickness="1" 
                        CornerRadius="4" Padding="16"
                        Visibility="{Binding HasAnomalies, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="All Price Anomalies" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding AllAnomalies}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  Background="White"
                                  RowHeight="48"
                                  CanUserResizeRows="False"
                                  FontSize="13">
                            
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#f8fafb"/>
                                    <Setter Property="Foreground" Value="#666"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#e2e8f0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="12,0"/>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='dd MMM yyyy'}" Width="100"/>
                                <DataGridTextColumn Header="Product" Binding="{Binding ItemName}" Width="180"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding TypeDisplay}" Width="150">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsIllusoryDiscount}" Value="True">
                                                    <Setter Property="Foreground" Value="#dc2626"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Actual" Binding="{Binding ActualPrice, StringFormat='{}{0:C2}'}" Width="80"/>
                                <DataGridTextColumn Header="Expected" Binding="{Binding ExpectedPrice, StringFormat='{}{0:C2}'}" Width="80"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
