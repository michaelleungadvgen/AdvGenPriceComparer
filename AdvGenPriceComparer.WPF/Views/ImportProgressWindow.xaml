<Window x:Class="AdvGenPriceComparer.WPF.Views.ImportProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Importing Data..." 
        Height="280" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="Importing Data" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   Margin="0,0,0,10"/>

        <!-- Description -->
        <TextBlock Grid.Row="1" 
                   Text="Please wait while your data is being imported..."
                   Foreground="Gray"
                   Margin="0,0,0,15"/>

        <!-- Current Item -->
        <TextBlock Grid.Row="2" 
                   Text="{Binding CurrentItem, FallbackValue='Preparing...'}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"
                   TextTrimming="CharacterEllipsis"
                   Foreground="{DynamicResource SystemAccentColorBrush}"/>

        <!-- Progress Bar -->
        <ProgressBar Grid.Row="3" 
                     Height="25"
                     Minimum="0" 
                     Maximum="100"
                     Value="{Binding ProgressPercentage, FallbackValue=0}"
                     IsIndeterminate="{Binding IsIndeterminate, FallbackValue=True}"/>

        <!-- Progress Details -->
        <Grid Grid.Row="4" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       Text="{Binding StatusMessage, FallbackValue='Initializing...'}"
                       Foreground="Gray"
                       FontSize="12"/>
            
            <TextBlock Grid.Column="1" 
                       Text="{Binding ProgressText, FallbackValue='0 / 0', StringFormat='{}{0}'}"
                       FontWeight="SemiBold"
                       FontSize="12"/>
        </Grid>

        <!-- Statistics -->
        <Border Grid.Row="5" 
                Background="{DynamicResource SystemAltMediumLowColor}" 
                CornerRadius="4"
                Padding="10,8"
                Margin="0,15,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Items Created" FontSize="10" Foreground="Gray"/>
                    <TextBlock Text="{Binding ItemsCreated, FallbackValue='0'}" 
                               FontSize="16" 
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="Green"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Price Records" FontSize="10" Foreground="Gray"/>
                    <TextBlock Text="{Binding PriceRecordsCreated, FallbackValue='0'}" 
                               FontSize="16" 
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="Blue"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Errors" FontSize="10" Foreground="Gray"/>
                    <TextBlock Text="{Binding ErrorCount, FallbackValue='0'}" 
                               FontSize="16" 
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{Binding ErrorCount, Converter={StaticResource ErrorCountToBrushConverter}, FallbackValue=Gray}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Cancel Button -->
        <Button Grid.Row="6" 
                Content="Cancel" 
                Width="80" 
                Height="28"
                HorizontalAlignment="Right"
                Margin="0,15,0,0"
                Command="{Binding CancelCommand}"
                Visibility="{Binding CanCancel, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"/>
    </Grid>
</Window>
