<Window x:Class="AdvGenPriceComparer.WPF.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AdvGenPriceComparer.WPF.ViewModels"
        Title="Settings" Height="600" Width="850"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterOwner">

    <Window.DataContext>
        <vm:SettingsViewModel/>
    </Window.DataContext>

    <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" Padding="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Navigation -->
            <Border Grid.Column="0" 
                    Background="#F5F5F5" 
                    CornerRadius="8" 
                    Padding="10"
                    Margin="0,0,15,0">
                <StackPanel>
                    <TextBlock Text="Settings" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               Margin="5,0,0,20"/>
                    
                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" 
                                        Height="40"
                                        Margin="0,2"
                                        HorizontalContentAlignment="Left"
                                        Padding="15,0"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Foreground" Value="#333"/>
                                            <Setter Property="FontSize" Value="14"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding}" Value="{Binding DataContext.SelectedCategory, RelativeSource={RelativeSource AncestorType=Window}}">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="Foreground" Value="#0078D4"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#E8E8E8"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Right Panel - Content -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Settings Content -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10,0">
                        <!-- General Settings -->
                        <StackPanel Visibility="{Binding SelectedCategory, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=General}">
                            <TextBlock Text="General Settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>
                            
                            <!-- Appearance -->
                            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="Appearance" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                    
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Application Theme" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" 
                                                  ItemsSource="{Binding AvailableThemes}"
                                                  SelectedItem="{Binding ApplicationTheme}"
                                                  Width="200"
                                                  HorizontalAlignment="Left"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Currency -->
                            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="Currency" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                    
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Default Currency" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" 
                                                  ItemsSource="{Binding AvailableCurrencies}"
                                                  SelectedItem="{Binding DefaultCurrency}"
                                                  Width="120"
                                                  HorizontalAlignment="Left"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Notifications -->
                            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="Notifications" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                    
                                    <CheckBox Content="Show Notifications" 
                                              IsChecked="{Binding ShowNotifications}"
                                              Margin="0,0,0,10"/>
                                    <CheckBox Content="Enable Auto-Update Check" 
                                              IsChecked="{Binding EnableAutoUpdate}"
                                              Margin="0,0,0,10"/>
                                    
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Price Alert Threshold (days)" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" 
                                                Minimum="1" 
                                                Maximum="30" 
                                                Value="{Binding PriceAlertThreshold}"
                                                Width="200"
                                                HorizontalAlignment="Left"/>
                                    </Grid>
                                    <TextBlock Text="{Binding PriceAlertThreshold, StringFormat='Current: {0} days'}" 
                                               Foreground="#666" 
                                               FontSize="12"
                                               Margin="150,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Database Settings -->
                        <StackPanel Visibility="{Binding SelectedCategory, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Database}">
                            <TextBlock Text="Database Configuration" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>
                            
                            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="Database Provider" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                    
                                    <ComboBox ItemsSource="{Binding AvailableDatabaseProviders}"
                                              SelectedItem="{Binding DatabaseProvider}"
                                              Width="200"
                                              HorizontalAlignment="Left"
                                              Margin="0,0,0,20"/>

                                    <!-- LiteDB Settings -->
                                    <StackPanel Visibility="{Binding IsLiteDbSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Database Path" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" 
                                                     Text="{Binding LiteDbPath}" 
                                                     IsReadOnly="True"
                                                     Background="#F5F5F5"
                                                     Padding="8,5"/>
                                            <Button Grid.Column="2" 
                                                    Content="Browse..." 
                                                    Command="{Binding BrowseLiteDbPathCommand}"
                                                    Margin="10,0,0,0"
                                                    Padding="15,5"/>
                                        </Grid>
                                        
                                        <TextBlock Text="LiteDB is an embedded NoSQL database. The database file is stored locally on your machine." 
                                                   Foreground="#666" 
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- AdvGenNoSQL Settings -->
                                    <StackPanel Visibility="{Binding IsNoSqlSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Server Host" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" 
                                                     Text="{Binding ServerHost}" 
                                                     Padding="8,5"/>
                                        </Grid>
                                        
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="200"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Server Port" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" 
                                                     Text="{Binding ServerPort}" 
                                                     Padding="8,5"/>
                                        </Grid>
                                        
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="API Key" VerticalAlignment="Center"/>
                                            <PasswordBox Grid.Column="1" 
                                                         Password="{Binding ApiKey}" 
                                                         Padding="8,5"/>
                                        </Grid>
                                        
                                        <Button Content="Test Connection" 
                                                Command="{Binding TestConnectionCommand}"
                                                HorizontalAlignment="Left"
                                                Padding="20,8"
                                                Margin="0,10,0,0"/>
                                        
                                        <TextBlock Text="AdvGenNoSQL requires connection to an external database server." 
                                                   Foreground="#666" 
                                                   FontSize="12"
                                                   Margin="0,15,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Import/Export Settings -->
                        <StackPanel Visibility="{Binding SelectedCategory, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter='Import/Export'}">
                            <TextBlock Text="Import/Export Settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>
                            
                            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="Export Settings" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                    
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Default Export Path" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" 
                                                 Text="{Binding DefaultExportPath}" 
                                                 IsReadOnly="True"
                                                 Background="#F5F5F5"
                                                 Padding="8,5"/>
                                        <Button Grid.Column="2" 
                                                Content="Browse..." 
                                                Command="{Binding BrowseExportPathCommand}"
                                                Margin="10,0,0,0"
                                                Padding="15,5"/>
                                    </Grid>
                                    
                                    <CheckBox Content="Compress export files (ZIP)" 
                                              IsChecked="{Binding CompressExports}"/>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="Import Settings" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                    
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Default Import Path" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" 
                                                 Text="{Binding DefaultImportPath}" 
                                                 IsReadOnly="True"
                                                 Background="#F5F5F5"
                                                 Padding="8,5"/>
                                        <Button Grid.Column="2" 
                                                Content="Browse..." 
                                                Command="{Binding BrowseImportPathCommand}"
                                                Margin="10,0,0,0"
                                                Padding="15,5"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Notifications Settings -->
                        <StackPanel Visibility="{Binding SelectedCategory, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Notifications}">
                            <TextBlock Text="Notification Preferences" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>
                            
                            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="Price Alerts" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                    
                                    <CheckBox Content="Enable price drop notifications" 
                                              IsChecked="{Binding ShowNotifications}"
                                              Margin="0,0,0,10"/>
                                    <CheckBox Content="Enable deal expiration reminders" 
                                              IsChecked="{Binding EnableAutoUpdate}"
                                              Margin="0,0,0,10"/>
                                    <CheckBox Content="Weekly specials digest" 
                                              IsChecked="True"
                                              IsEnabled="False"
                                              Margin="0,0,0,10"/>
                                    
                                    <TextBlock Text="Note: Notifications require the application to be running." 
                                               Foreground="#666" 
                                               FontSize="12"
                                               Margin="0,15,0,0"
                                               FontStyle="Italic"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- About Settings -->
                        <StackPanel Visibility="{Binding SelectedCategory, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=About}">
                            <TextBlock Text="About" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>
                            
                            <Border Background="White" CornerRadius="8" Padding="30" Margin="0,0,0,15">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="80" Height="80" 
                                            Background="#0078D4" 
                                            CornerRadius="12"
                                            Margin="0,0,0,20">
                                        <TextBlock Text="PC" 
                                                   Foreground="White" 
                                                   FontSize="36" 
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    
                                    <TextBlock Text="AdvGen Price Comparer" 
                                               FontSize="20" 
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,5"/>
                                    <TextBlock Text="Grocery Price Tracking &amp; Comparison" 
                                               Foreground="#666"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,25"/>
                                    
                                    <Grid HorizontalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Version:" Foreground="#666"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding ApplicationVersion}" FontWeight="SemiBold"/>
                                        
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Build Date:" Foreground="#666" Margin="0,5"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding BuildDate}" FontWeight="SemiBold" Margin="0,5"/>
                                        
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text=".NET Version:" Foreground="#666"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding DotNetVersion}" FontWeight="SemiBold"/>
                                        
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Database:" Foreground="#666" Margin="0,5"/>
                                        <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding DatabaseVersion}" FontWeight="SemiBold" Margin="0,5"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom Buttons -->
                <Border Grid.Row="1" 
                        Background="#F5F5F5" 
                        CornerRadius="8" 
                        Padding="15"
                        Margin="10,15,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Reset to Defaults" 
                                Command="{Binding ResetCommand}"
                                Padding="20,10"
                                Margin="0,0,10,0"
                                Background="#E74C3C"
                                Foreground="White"
                                BorderThickness="0"/>
                        <Button Content="Save Changes" 
                                Command="{Binding SaveCommand}"
                                Padding="25,10"
                                Background="#27AE60"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
</Window>
