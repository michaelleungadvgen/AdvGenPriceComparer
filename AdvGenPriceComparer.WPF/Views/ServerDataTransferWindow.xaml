<Window x:Class="AdvGenPriceComparer.WPF.Views.ServerDataTransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Server Data Transfer" 
        Height="750" 
        Width="750"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="650"
        MinHeight="600">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource SystemAccentColorBrush}" Padding="20,15">
            <StackPanel>
                <TextBlock Text="Server Data Transfer" FontSize="24" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Upload or download price data to/from the AdvGenNoSQLServer"
                           Foreground="White" Opacity="0.9" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                <!-- Connection Settings Section -->
                <GroupBox Header="Server Connection" Margin="0,0,0,15">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Server Host -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Server Host:" 
                                   FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Grid.Row="1" Grid.Column="0" 
                                 Text="{Binding ServerHost, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center"
                                 Padding="8,5"
                                 Margin="0,0,10,10"
                                 IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBooleanConverter}}"/>

                        <!-- Server Port -->
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Port:" 
                                   FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                                 Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center"
                                 Padding="8,5"
                                 Margin="0,0,0,10"
                                 IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBooleanConverter}}"/>

                        <!-- Database Name -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Database Name:" 
                                   FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Grid.Row="3" Grid.Column="0" 
                                 Text="{Binding DatabaseName, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center"
                                 Padding="8,5"
                                 Margin="0,0,10,10"
                                 IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBooleanConverter}}"/>

                        <!-- Use SSL -->
                        <CheckBox Grid.Row="2" Grid.Column="1" 
                                  Content="Use SSL/TLS"
                                  IsChecked="{Binding UseSsl}"
                                  VerticalAlignment="Center"
                                  Margin="0,15,0,10"
                                  IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBooleanConverter}}"/>

                        <!-- API Key -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                                   Text="API Key:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <PasswordBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                                     x:Name="ApiKeyPasswordBox"
                                     VerticalContentAlignment="Center"
                                     Padding="8,5"
                                     Margin="0,0,0,10"
                                     IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBooleanConverter}}"/>
                    </Grid>
                </GroupBox>

                <!-- Connection Status -->
                <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                        Padding="15"
                        Margin="0,0,0,15"
                        CornerRadius="4"
                        Visibility="{Binding IsConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="12" Height="12" Fill="#22c55e" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding ConnectionStatus}" 
                                   FontWeight="SemiBold" 
                                   Foreground="#22c55e"/>
                    </StackPanel>
                </Border>

                <!-- Progress Section -->
                <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                        Padding="15"
                        Margin="0,0,0,15"
                        Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="{Binding StatusMessage}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>
                        <ProgressBar Value="{Binding ProgressPercentage}"
                                     Maximum="100"
                                     Height="20"/>
                        <TextBlock Text="{Binding ProgressPercentage, StringFormat='{}{0}%'}"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Upload Section -->
                <GroupBox Header="Upload to Server" Margin="0,0,0,15">
                    <StackPanel Margin="10">
                        <TextBlock Text="Select data to upload to the server:" 
                                   Margin="0,0,0,10"/>
                        
                        <CheckBox Content="Items (Products)" 
                                  IsChecked="{Binding UploadItems}"
                                  Margin="0,0,0,5"
                                  IsEnabled="{Binding IsConnected}"/>
                        <CheckBox Content="Places (Stores)" 
                                  IsChecked="{Binding UploadPlaces}"
                                  Margin="0,0,0,5"
                                  IsEnabled="{Binding IsConnected}"/>
                        <CheckBox Content="Price Records" 
                                  IsChecked="{Binding UploadPriceRecords}"
                                  Margin="0,0,0,15"
                                  IsEnabled="{Binding IsConnected}"/>

                        <Button Content="Upload Data"
                                Command="{Binding UploadCommand}"
                                Padding="20,8"
                                HorizontalAlignment="Left"
                                Background="{DynamicResource SystemAccentColorBrush}"
                                Foreground="White"
                                IsEnabled="{Binding IsConnected}"/>
                    </StackPanel>
                </GroupBox>

                <!-- Download Section -->
                <GroupBox Header="Download from Server" Margin="0,0,0,15">
                    <StackPanel Margin="10">
                        <TextBlock Text="Select data to download from the server:" 
                                   Margin="0,0,0,10"/>
                        
                        <CheckBox Content="Items (Products)" 
                                  IsChecked="{Binding DownloadItems}"
                                  Margin="0,0,0,5"
                                  IsEnabled="{Binding IsConnected}"/>
                        <CheckBox Content="Places (Stores)" 
                                  IsChecked="{Binding DownloadPlaces}"
                                  Margin="0,0,0,5"
                                  IsEnabled="{Binding IsConnected}"/>
                        <CheckBox Content="Price Records" 
                                  IsChecked="{Binding DownloadPriceRecords}"
                                  Margin="0,0,0,15"
                                  IsEnabled="{Binding IsConnected}"/>

                        <!-- Date Range Filter -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="From Date:" 
                                       Margin="0,0,0,5"/>
                            <DatePicker Grid.Row="1" Grid.Column="0" 
                                        SelectedDate="{Binding DateFrom}"
                                        Margin="0,0,10,0"
                                        IsEnabled="{Binding IsConnected}"/>

                            <TextBlock Grid.Row="0" Grid.Column="1" Text="To Date:" 
                                       Margin="0,0,0,5"/>
                            <DatePicker Grid.Row="1" Grid.Column="1" 
                                        SelectedDate="{Binding DateTo}"
                                        IsEnabled="{Binding IsConnected}"/>
                        </Grid>

                        <Button Content="Download Data"
                                Command="{Binding DownloadCommand}"
                                Padding="20,8"
                                HorizontalAlignment="Left"
                                Background="{DynamicResource SystemAccentColorBrush}"
                                Foreground="White"
                                IsEnabled="{Binding IsConnected}"/>
                    </StackPanel>
                </GroupBox>

                <!-- Result Section -->
                <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                        Padding="15"
                        Margin="0,0,0,15"
                        Visibility="{Binding ShowResult, Converter={StaticResource BooleanToVisibilityConverter}}"
                        CornerRadius="4">
                    <TextBlock Text="{Binding TransferResult}"
                               TextWrapping="Wrap"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" Background="{DynamicResource SystemAltMediumColor}" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Connection Buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="Connect"
                            Command="{Binding ConnectCommand}"
                            Padding="20,8"
                            Margin="0,0,10,0"
                            Background="{DynamicResource SystemAccentColorBrush}"
                            Foreground="White"
                            Visibility="{Binding IsConnected, Converter={StaticResource InverseBooleanConverter}}"/>
                    <Button Content="Disconnect"
                            Command="{Binding DisconnectCommand}"
                            Padding="20,8"
                            Margin="0,0,10,0"
                            Visibility="{Binding IsConnected, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <!-- Close Button -->
                <Button Grid.Column="1"
                        Content="Close"
                        Command="{Binding CloseCommand}"
                        Padding="20,8"
                        HorizontalAlignment="Right"/>
            </Grid>
        </Border>

    </Grid>
</Window>
