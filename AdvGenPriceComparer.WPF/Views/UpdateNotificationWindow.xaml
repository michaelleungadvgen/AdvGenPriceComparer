<Window x:Class="AdvGenPriceComparer.WPF.Views.UpdateNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Update Available" 
        Height="500" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        FontFamily="{DynamicResource ContentControlThemeFontFamily}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with Icon and Title -->
        <Border Grid.Row="0" 
                Background="{DynamicResource SystemAccentColorBrush}" 
                Padding="20,15">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE896;" 
                           FontFamily="Segoe Fluent Icons, Segoe UI Symbol" 
                           FontSize="32" 
                           Foreground="White"
                           Margin="0,0,15,0"
                           VerticalAlignment="Center"/>
                <StackPanel>
                    <TextBlock Text="Update Available!" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock x:Name="VersionText"
                               FontSize="14" 
                               Foreground="White"
                               Opacity="0.9"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Release Info -->
        <StackPanel Grid.Row="1" Margin="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="Current Version:"
                           FontWeight="SemiBold"
                           Margin="0,0,10,5"/>
                <TextBlock x:Name="CurrentVersionText"
                           Grid.Row="0" Grid.Column="1"
                           Margin="0,0,0,5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="Latest Version:"
                           FontWeight="SemiBold"
                           Margin="0,0,10,5"/>
                <TextBlock x:Name="LatestVersionText"
                           Grid.Row="1" Grid.Column="1"
                           Foreground="{DynamicResource SystemAccentColorBrush}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" 
                           Text="Release Date:"
                           FontWeight="SemiBold"
                           Margin="0,0,10,0"/>
                <TextBlock x:Name="ReleaseDateText"
                           Grid.Row="2" Grid.Column="1"/>
            </Grid>

            <Border x:Name="MandatoryBanner"
                    Background="#FFFCE8"
                    BorderBrush="#FFD700"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10,8"
                    Margin="0,15,0,0"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE814;" 
                               FontFamily="Segoe Fluent Icons, Segoe UI Symbol"
                               Foreground="#D83B01"
                               FontSize="16"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="This is a mandatory update. Please update to continue using all features."
                               Foreground="#D83B01"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Release Notes -->
        <GroupBox Grid.Row="2" 
                  Header="Release Notes" 
                  Margin="20,0,20,15"
                  Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="ReleaseNotesText"
                           TextWrapping="Wrap"
                           LineHeight="20"/>
            </ScrollViewer>
        </GroupBox>

        <!-- Buttons -->
        <Border Grid.Row="3" 
                Background="{DynamicResource SystemAltMediumColor}" 
                Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="LaterButton"
                        Content="Remind Me Later"
                        Padding="20,8"
                        Margin="0,0,10,0"
                        Click="LaterButton_Click"/>
                <Button x:Name="DownloadButton"
                        Content="Download Update"
                        Padding="20,8"
                        Background="{DynamicResource SystemAccentColorBrush}"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Click="DownloadButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
