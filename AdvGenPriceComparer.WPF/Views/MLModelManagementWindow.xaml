<Window x:Class="AdvGenPriceComparer.WPF.Views.MLModelManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ML Model Management"
        Height="700"
        Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="600"
        MinWidth="700"
        Background="#f5f5f5">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style TargetType="Button" x:Key="ActionButtonStyle">
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#111"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#ccc"/>
                    <Setter Property="Foreground" Value="#666"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="SecondaryButtonStyle">
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#ddd"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#f0f0f0"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#f5f5f5"/>
                    <Setter Property="Foreground" Value="#999"/>
                    <Setter Property="BorderBrush" Value="#e0e0e0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="GroupBox" x:Key="CardStyle">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#e0e0e0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" 
                                        Background="#f9f9f9"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16,12"
                                        CornerRadius="4,4,0,0">
                                    <ContentPresenter ContentSource="Header"
                                                    TextBlock.FontSize="14"
                                                    TextBlock.FontWeight="SemiBold"
                                                    TextBlock.Foreground="#333"/>
                                </Border>
                                <ContentPresenter Grid.Row="1" 
                                                Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="ML Model Management" 
                      FontSize="24" 
                      FontWeight="Bold" 
                      Foreground="#111"/>
            <TextBlock Text="Train, test, and manage category prediction models"
                      FontSize="13"
                      Foreground="#666"
                      Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Actions -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <!-- Current Model Status -->
                <GroupBox Header="Current Model" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <Ellipse Grid.Row="0" Grid.Column="0" 
                                    Width="12" Height="12" 
                                    Fill="{Binding ModelStatusColor}"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" 
                                      Text="{Binding ModelStatusText}"
                                      FontWeight="SemiBold"
                                      FontSize="13"
                                      VerticalAlignment="Center"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                      Text="{Binding ModelPath}"
                                      FontSize="11"
                                      Foreground="#666"
                                      TextWrapping="Wrap"
                                      Margin="0,8,0,0"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                      Text="{Binding ModelLastTrained}"
                                      FontSize="11"
                                      Foreground="#666"
                                      Margin="0,4,0,0"/>
                            
                            <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                      Text="{Binding ModelSize}"
                                      FontSize="11"
                                      Foreground="#666"
                                      Margin="0,4,0,0"/>
                        </Grid>

                        <Button Content="🔄 Reload Model" AutomationProperties.Name="Reload Model"
                                Command="{Binding ReloadModelCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                IsEnabled="{Binding IsNotBusy}"/>
                    </StackPanel>
                </GroupBox>

                <!-- Training Actions -->
                <GroupBox Header="Training" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Button Content="📊 Train from Database"
                                Command="{Binding TrainFromDatabaseCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                IsEnabled="{Binding IsNotBusy}"/>
                        <TextBlock Text="Uses categorized items in database (min 100)"
                                  FontSize="11"
                                  Foreground="#666"
                                  TextWrapping="Wrap"
                                  Margin="0,-4,0,12"/>

                        <Button Content="📁 Train from CSV"
                                Command="{Binding TrainFromCsvCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                IsEnabled="{Binding IsNotBusy}"/>
                        <TextBlock Text="Import training data from CSV file"
                                  FontSize="11"
                                  Foreground="#666"
                                  Margin="0,-4,0,12"/>

                        <Button Content="🔄 Retrain Model" AutomationProperties.Name="Retrain Model"
                                Command="{Binding RetrainModelCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                IsEnabled="{Binding CanRetrain}"/>
                        <TextBlock Text="Improve model with recent categorizations"
                                  FontSize="11"
                                  Foreground="#666"
                                  Margin="0,-4,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- Training Stats -->
                <GroupBox Header="Last Training" Style="{StaticResource CardStyle}"
                         Visibility="{Binding HasTrainingResult, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                      Text="Accuracy:"
                                      FontSize="12"
                                      Foreground="#666"
                                      Margin="0,0,12,6"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" 
                                      Text="{Binding LastTrainingAccuracy}"
                                      FontSize="12"
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,6"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                      Text="Items Used:"
                                      FontSize="12"
                                      Foreground="#666"
                                      Margin="0,0,12,6"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" 
                                      Text="{Binding LastTrainingItemCount}"
                                      FontSize="12"
                                      Margin="0,0,0,6"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" 
                                      Text="Duration:"
                                      FontSize="12"
                                      Foreground="#666"
                                      Margin="0,0,12,6"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" 
                                      Text="{Binding LastTrainingDuration}"
                                      FontSize="12"
                                      Margin="0,0,0,6"/>
                            
                            <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                      Text="{Binding LastTrainingMessage}"
                                      FontSize="11"
                                      TextWrapping="Wrap"
                                      Foreground="{Binding LastTrainingMessageColor}"
                                      Margin="0,4,0,0"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <!-- Right Panel - Testing -->
            <GroupBox Grid.Column="1" Header="Test Prediction" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Test Input -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Product Name *" 
                                  FontSize="13"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,6"/>
                        <TextBox Text="{Binding TestProductName, UpdateSourceTrigger=PropertyChanged}"
                                FontSize="13"
                                Padding="10"
                                BorderBrush="#ddd"
                                BorderThickness="1"/>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Brand" 
                                      FontSize="13"
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,6"/>
                            <TextBox Text="{Binding TestBrand, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="13"
                                    Padding="10"
                                    BorderBrush="#ddd"
                                    BorderThickness="1"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Description" 
                                      FontSize="13"
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,6"/>
                            <TextBox Text="{Binding TestDescription, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="13"
                                    Padding="10"
                                    BorderBrush="#ddd"
                                    BorderThickness="1"/>
                        </StackPanel>
                    </Grid>

                    <Button Grid.Row="2"
                            Content="🧪 Test Prediction"
                            Command="{Binding TestPredictionCommand}"
                            Style="{StaticResource ActionButtonStyle}"
                            HorizontalAlignment="Left"
                            MinWidth="150"
                            IsEnabled="{Binding CanTestPrediction}"
                            Margin="0,0,0,20"/>

                    <!-- Prediction Results -->
                    <Border Grid.Row="3"
                            Background="#f9f9f9"
                            BorderBrush="#e0e0e0"
                            BorderThickness="1"
                            Padding="16"
                            CornerRadius="4"
                            Visibility="{Binding HasPredictionResult, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Prediction Result" 
                                      FontSize="14"
                                      FontWeight="Bold"
                                      Margin="0,0,0,12"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" 
                                          Text="Category:"
                                          FontSize="13"
                                          Foreground="#666"
                                          Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" 
                                          Text="{Binding PredictedCategory}"
                                          FontSize="16"
                                          FontWeight="Bold"
                                          Foreground="#16a34a"
                                          Margin="0,0,0,8"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" 
                                          Text="Confidence:"
                                          FontSize="13"
                                          Foreground="#666"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" 
                                          Text="{Binding PredictionConfidence}"
                                          FontSize="14"
                                          FontWeight="SemiBold"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Category Scores -->
                    <Border Grid.Row="4"
                            Background="White"
                            BorderBrush="#e0e0e0"
                            BorderThickness="1"
                            Padding="16"
                            CornerRadius="4"
                            Visibility="{Binding HasCategoryScores, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" 
                                      Text="Category Confidence Scores"
                                      FontSize="13"
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,12"/>
                            
                            <ScrollViewer Grid.Row="1" 
                                         VerticalScrollBarVisibility="Auto"
                                         MaxHeight="200">
                                <ItemsControl ItemsSource="{Binding CategoryScores}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <TextBlock Grid.Column="0" 
                                                          Text="{Binding Category}"
                                                          FontSize="12"
                                                          VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" 
                                                          Text="{Binding ScoreText}"
                                                          FontSize="12"
                                                          FontWeight="SemiBold"
                                                          HorizontalAlignment="Right"
                                                          VerticalAlignment="Center"/>
                                                <ProgressBar Grid.Column="2"
                                                            Value="{Binding ScorePercentage}"
                                                            Maximum="100"
                                                            Height="8"
                                                            Margin="8,0,0,0"
                                                            Background="#e0e0e0"
                                                            Foreground="{Binding BarColor}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Footer - Progress and Status -->
        <Grid Grid.Row="2" Margin="0,4,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <ProgressBar Grid.Row="0"
                        Height="6"
                        Margin="0,0,0,8"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                        IsIndeterminate="True"
                        Background="#e0e0e0"
                        Foreground="#111"/>
            
            <TextBlock Grid.Row="1"
                      Text="{Binding StatusMessage}"
                      FontSize="12"
                      Foreground="#666"
                      TextTrimming="CharacterEllipsis"
                      Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </Grid>
    </Grid>
</Window>
