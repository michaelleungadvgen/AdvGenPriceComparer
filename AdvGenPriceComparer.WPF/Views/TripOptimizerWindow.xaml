<Window x:Class="AdvGenPriceComparer.WPF.Views.TripOptimizerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AdvGenPriceComparer.WPF.ViewModels"
        xmlns:converters="clr-namespace:AdvGenPriceComparer.WPF.Converters"
        mc:Ignorable="d"
        Title="Trip Optimizer" 
        Height="800" Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>

        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Header Style -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#212529"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Store Stop Card Style -->
        <Style x:Key="StoreStopCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DEE2E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0D6EFD" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="🛒 Trip Optimizer" 
                               FontSize="24" FontWeight="Bold" Foreground="White" AutomationProperties.Name="Trip Optimizer"/>
                    <TextBlock Text="Plan the most efficient shopping route across multiple stores"
                               Foreground="White" Opacity="0.9" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🔄 Refresh" 
                            Command="{Binding RefreshListsCommand}"
                            Padding="12,8" Margin="0,0,8,0"
                            Background="#FFFFFF" Foreground="#0D6EFD" BorderThickness="0" AutomationProperties.Name="Refresh"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Configuration -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <!-- Shopping List Selection -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="📋 Shopping List" Style="{StaticResource SectionHeaderStyle}" AutomationProperties.Name="Shopping List"/>

                            <ComboBox ItemsSource="{Binding AvailableShoppingLists}"
                                      SelectedItem="{Binding SelectedShoppingList}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,0,8"/>

                            <TextBlock FontSize="12" Foreground="#6C757D">
                                <Run Text="Items: "/>
                                <Run Text="{Binding SelectedListItemsCount}" FontWeight="SemiBold"/>
                                <Run Text=" | Estimated: "/>
                                <Run Text="{Binding SelectedListTotal, StringFormat='${0:F2}'}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Optimization Options -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="⚙️ Optimization Strategy" Style="{StaticResource SectionHeaderStyle}" AutomationProperties.Name="Optimization Strategy"/>

                            <ComboBox ItemsSource="{Binding Source={StaticResource OptimizationStrategyEnum}}"
                                      SelectedItem="{Binding SelectedStrategy}"
                                      Margin="0,0,0,8">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Text="{Binding StrategyDescription}" 
                                       FontSize="12" Foreground="#6C757D" 
                                       TextWrapping="Wrap" Margin="0,0,0,16"/>

                            <TextBlock Text="Maximum Stores:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <Slider Minimum="1" Maximum="10" TickFrequency="1" 
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding MaxStores}"/>
                            <TextBlock Text="{Binding MaxStores}" 
                                       HorizontalAlignment="Center" FontSize="12" 
                                       Foreground="#6C757D" Margin="0,0,0,12"/>

                            <TextBlock Text="Maximum Distance (km):" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <Slider Minimum="5" Maximum="100" TickFrequency="5"
                                    Value="{Binding MaxDistanceKm}"/>
                            <TextBlock Text="{Binding MaxDistanceKm, StringFormat='{}{0:F0} km'}" 
                                       HorizontalAlignment="Center" FontSize="12"
                                       Foreground="#6C757D" Margin="0,0,0,12"/>

                            <TextBlock Text="Minimum Savings Threshold ($):" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <Slider Minimum="0" Maximum="20" TickFrequency="1"
                                    Value="{Binding MinSavingsThreshold}"/>
                            <TextBlock Text="{Binding MinSavingsThreshold, StringFormat='${0:F2}'}" 
                                       HorizontalAlignment="Center" FontSize="12"
                                       Foreground="#6C757D" Margin="0,0,0,12"/>

                            <CheckBox Content="Prioritize one-stop shopping"
                                      IsChecked="{Binding PrioritizeOneStop}"
                                      Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Optimize Button -->
                    <Button Command="{Binding OptimizeCommand}"
                            IsEnabled="{Binding CanOptimize}"
                            Background="#198754" Foreground="White"
                            Padding="16,12" FontSize="16" FontWeight="SemiBold"
                            BorderThickness="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚀 " FontSize="18"/>
                            <TextBlock Text="Optimize My Trip"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="{Binding StatusMessage}" 
                               TextWrapping="Wrap"
                               Foreground="#6C757D" 
                               FontSize="12"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Right Panel: Results -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Results Summary -->
                    <Border Grid.Row="0" Style="{StaticResource CardStyle}"
                            Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Stores -->
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding NumberOfStores}" 
                                           FontSize="32" FontWeight="Bold" 
                                           Foreground="#0D6EFD" HorizontalAlignment="Center"/>
                                <TextBlock Text="Stores" FontSize="12" Foreground="#6C757D" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Items -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TotalItems}" 
                                           FontSize="32" FontWeight="Bold"
                                           Foreground="#198754" HorizontalAlignment="Center"/>
                                <TextBlock Text="Items" FontSize="12" Foreground="#6C757D" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Distance -->
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock FontSize="32" FontWeight="Bold"
                                           Foreground="#6F42C1" HorizontalAlignment="Center">
                                    <Run Text="{Binding TotalDistanceKm, StringFormat='{}{0:F1}'}"/>
                                    <Run Text="km" FontSize="16"/>
                                </TextBlock>
                                <TextBlock Text="Distance" FontSize="12" Foreground="#6C757D" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Time -->
                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding FormattedTotalTime}" 
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="#FD7E14" HorizontalAlignment="Center"/>
                                <TextBlock Text="Est. Time" FontSize="12" Foreground="#6C757D" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Cost -->
                            <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                <TextBlock FontSize="28" FontWeight="Bold"
                                           Foreground="#DC3545" HorizontalAlignment="Center">
                                    <Run Text="$"/>
                                    <Run Text="{Binding TotalCost, StringFormat='{}{0:F0}'}"/>
                                </TextBlock>
                                <TextBlock Text="Total" FontSize="12" Foreground="#6C757D" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- No Results Message -->
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}"
                            Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverted}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                            <TextBlock Text="🗺️" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <TextBlock Text="Ready to Optimize Your Trip" 
                                       FontSize="20" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Select a shopping list and click 'Optimize My Trip' to get your personalized shopping route."
                                       TextWrapping="Wrap" TextAlignment="Center"
                                       Foreground="#6C757D" MaxWidth="400"/>
                        </StackPanel>
                    </Border>

                    <!-- Store Stops -->
                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="🛍️ Shopping Route" 
                                       Style="{StaticResource SectionHeaderStyle}" AutomationProperties.Name="Shopping Route"/>

                            <!-- Store Stops List -->
                            <ItemsControl ItemsSource="{Binding StoreStops}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:StoreStopViewModel}">
                                        <Border Style="{StaticResource StoreStopCardStyle}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Store Header -->
                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0" 
                                                            Background="#0D6EFD" 
                                                            CornerRadius="20"
                                                            Width="36" Height="36"
                                                            Margin="0,0,12,0">
                                                        <TextBlock Text="{Binding StopNumber}"
                                                                   Foreground="White" FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding StoreName}"
                                                                   FontSize="18" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Chain}"
                                                                   FontSize="12" Foreground="#6C757D"/>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="2" 
                                                               Text="{Binding TravelInfo}"
                                                               FontSize="12"
                                                               Foreground="#6C757D"
                                                               VerticalAlignment="Center"/>
                                                </Grid>

                                                <!-- Address -->
                                                <TextBlock Grid.Row="1" 
                                                           Text="{Binding Address}"
                                                           FontSize="12" Foreground="#6C757D"
                                                           Margin="48,4,0,8"/>

                                                <!-- Items List -->
                                                <Border Grid.Row="2" 
                                                        Background="#F8F9FA"
                                                        CornerRadius="4"
                                                        Margin="48,8,0,8">
                                                    <ItemsControl ItemsSource="{Binding Items}"
                                                                  Margin="12,8">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type vm:TripItemViewModel}">
                                                                <Grid Margin="0,4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding DisplayName}"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                        <TextBlock Text="{Binding QuantityDisplay}"
                                                                                   FontSize="12" Foreground="#6C757D"
                                                                                   Margin="8,0,0,0"
                                                                                   Visibility="{Binding QuantityDisplay, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                                    </StackPanel>

                                                                    <TextBlock Grid.Column="1" 
                                                                               Text="{Binding SavingsDisplay}"
                                                                               Foreground="#198754"
                                                                               FontSize="12"
                                                                               Margin="12,0"
                                                                               Visibility="{Binding HasSavings, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                                        <TextBlock Text="🎉" 
                                                                                   Visibility="{Binding IsOnSale, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                        <TextBlock Text="{Binding PriceDisplay}"
                                                                                   FontWeight="SemiBold"
                                                                                   Margin="4,0,0,0"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Border>

                                                <!-- Subtotal -->
                                                <TextBlock Grid.Row="3"
                                                           HorizontalAlignment="Right"
                                                           Margin="48,8,0,0">
                                                    <Run Text="Subtotal: " FontWeight="SemiBold"/>
                                                    <Run Text="{Binding Subtotal, StringFormat='${0:F2}'}" 
                                                         FontWeight="Bold" FontSize="16"/>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Unavailable Items -->
                            <Border Style="{StaticResource CardStyle}"
                                    Background="#FFF3CD"
                                    BorderBrush="#FFE69C"
                                    Visibility="{Binding UnavailableItemsCount, Converter={StaticResource IntToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="⚠️ Unavailable Items" 
                                               FontWeight="SemiBold" 
                                               Foreground="#856404" AutomationProperties.Name="Unavailable Items"/>
                                    <TextBlock Text="The following items could not be found at any store:"
                                               FontSize="12" 
                                               Foreground="#856404"
                                               Margin="0,4,0,8"/>
                                    <ItemsControl ItemsSource="{Binding UnavailableItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="12"
                                                           Foreground="#856404"
                                                           Margin="0,2"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Savings Summary -->
                            <Border Style="{StaticResource CardStyle}"
                                    Background="#D1ECF1"
                                    BorderBrush="#BEE5EB"
                                    Visibility="{Binding PotentialSavings, Converter={StaticResource DecimalToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Foreground="#0C5460">
                                        <Run Text="💰 Potential Savings: "/>
                                        <Run Text="{Binding PotentialSavings, StringFormat='${0:F2}'}"
                                             FontSize="18"/>
                                    </TextBlock>
                                    <TextBlock Text="By shopping at the recommended stores instead of a single store"
                                               FontSize="12"
                                               Foreground="#0C5460"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#DEE2E6" 
                BorderThickness="0,1,0,0" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Plan your shopping trips efficiently and save both time and money"
                           Foreground="#6C757D" FontSize="12"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="📋 Copy to Clipboard"
                            Command="{Binding ExportResultsCommand}"
                            Padding="12,8" Margin="0,0,8,0"
                            Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}" AutomationProperties.Name="Copy to Clipboard"/>
                    <Button Content="🖨️ Print"
                            Command="{Binding PrintResultsCommand}"
                            Padding="12,8"
                            Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}" AutomationProperties.Name="Print"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
