<Window x:Class="AdvGenPriceComparer.WPF.Views.BestPricesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AdvGenPriceComparer.WPF.ViewModels"
        mc:Ignorable="d"
        Title="Best Prices &amp; Deals" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ApplicationBackgroundBrush}">
    
    <Window.DataContext>
        <vm:BestPricesViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource SystemAccentColorBrush}" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Best Prices &amp; Deals" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Find the best prices and biggest savings across all stores"
                               Foreground="White" Opacity="0.9" Margin="0,5,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="🔄 Refresh" Padding="15,8" Margin="0,0,10,0"
                            Command="{Binding RefreshCommand}"
                            Background="White" Foreground="{DynamicResource SystemAccentColorBrush}" AutomationProperties.Name="Refresh"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Legend -->
        <Border Grid.Row="1" Background="{DynamicResource SystemAltLowColor}" Padding="15,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Legend: " FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Border Background="#FFD700" Padding="8,3" Margin="10,0,5,0" CornerRadius="3">
                    <TextBlock Text="🔥 BEST PRICE" FontSize="11" FontWeight="Bold"/>
                </Border>
                <Border Background="#4CAF50" Padding="8,3" Margin="5,0" CornerRadius="3">
                    <TextBlock Text="⭐ GREAT DEAL" FontSize="11" FontWeight="Bold" Foreground="White"/>
                </Border>
                <Border Background="#2196F3" Padding="8,3" Margin="5,0" CornerRadius="3">
                    <TextBlock Text="✓ GOOD DEAL" FontSize="11" FontWeight="Bold" Foreground="White"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Content Tabs -->
        <TabControl Grid.Row="2" Margin="10" SelectedIndex="{Binding SelectedTabIndex}">
            
            <!-- Best Deals Tab -->
            <TabItem Header="🔥 Best Deals">
                <Grid>
                    <DataGrid ItemsSource="{Binding BestDeals}" 
                              SelectedItem="{Binding SelectedDeal}"
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              RowHeight="40">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item" Binding="{Binding ItemName}" Width="*"/>
                            <DataGridTextColumn Header="Brand" Binding="{Binding Brand}" Width="120"/>
                            <DataGridTextColumn Header="Store" Binding="{Binding BestStoreName}" Width="120"/>
                            <DataGridTextColumn Header="Price" Width="80">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="BestPrice" StringFormat="${0:F2}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Savings %" Width="90">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="SavingsPercent" StringFormat="{}{0:F0}%"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Highlight" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding HighlightLevel, Converter={StaticResource HighlightLevelToTextConverter}}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground">
                                            <Setter.Value>
                                                <Binding Path="HighlightLevel" Converter="{StaticResource HighlightLevelToColorConverter}"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <TextBlock Text="No best deals found. Import some price data to see deals."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding BestDeals.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                </Grid>
            </TabItem>

            <!-- Historical Lows Tab -->
            <TabItem Header="📉 Historical Lows">
                <Grid>
                    <DataGrid ItemsSource="{Binding HistoricalLows}" 
                              SelectedItem="{Binding SelectedDeal}"
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              RowHeight="40">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item" Binding="{Binding ItemName}" Width="*"/>
                            <DataGridTextColumn Header="Store" Binding="{Binding BestStoreName}" Width="120"/>
                            <DataGridTextColumn Header="Current" Width="90">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="BestPrice" StringFormat="${0:F2}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Historical Low" Width="110">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="HistoricalLow" StringFormat="${0:F2}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Historical High" Width="110">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="HistoricalHigh" StringFormat="${0:F2}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Average" Width="90">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="AveragePrice" StringFormat="${0:F2}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <TextBlock Text="No historical lows found. More price history needed."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding HistoricalLows.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                </Grid>
            </TabItem>

            <!-- Best Savings Tab -->
            <TabItem Header="💰 Best Savings">
                <Grid>
                    <DataGrid ItemsSource="{Binding BestSavings}" 
                              SelectedItem="{Binding SelectedDeal}"
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              RowHeight="40">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item" Binding="{Binding ItemName}" Width="*"/>
                            <DataGridTextColumn Header="Store" Binding="{Binding BestStoreName}" Width="120"/>
                            <DataGridTextColumn Header="Price" Width="80">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="BestPrice" StringFormat="${0:F2}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Avg Price" Width="90">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="AveragePrice" StringFormat="${0:F2}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="You Save" Width="90">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="SavingsAmount" StringFormat="${0:F2}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Savings %" Width="90">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="SavingsPercent" StringFormat="{}{0:F0}%"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <TextBlock Text="No significant savings found. Import more price data."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding BestSavings.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="3" Background="{DynamicResource SystemAltMediumColor}" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                           Text="Best prices are calculated based on historical data. Prices highlighted in gold are at or near historical lows."
                           FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="View Details" Padding="20,8" Margin="0,0,10,0"
                            Command="{Binding ViewDetailsCommand}"
                            IsEnabled="{Binding CanViewDetails}"/>
                    <Button Content="Close" Padding="20,8" 
                            Command="{Binding CloseCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
