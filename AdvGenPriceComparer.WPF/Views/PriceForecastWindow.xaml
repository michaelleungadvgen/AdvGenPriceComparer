<Window x:Class="AdvGenPriceComparer.WPF.Views.PriceForecastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="700"
        Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="White"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#f8fafb" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1" Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Price Forecast" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="ML-powered price prediction using time series analysis" 
                               FontSize="13" Foreground="#666" Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Close"
                        Click="CloseButton_Click"
                        Width="80"
                        Height="36"
                        Background="#111"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="14"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Configuration Panel -->
        <Border Grid.Row="1" Background="#f9f9f9" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Item Selection -->
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Product:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding Items}"
                                  SelectedItem="{Binding SelectedItem}"
                                  DisplayMemberPath="Name"
                                  Padding="10,8"
                                  FontSize="13"/>
                    </StackPanel>

                    <!-- Store Selection -->
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Store (Optional):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding Places}"
                                  SelectedItem="{Binding SelectedPlace}"
                                  DisplayMemberPath="Name"
                                  Padding="10,8"
                                  FontSize="13"/>
                    </StackPanel>

                    <!-- Forecast Days -->
                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Text="Days to Forecast:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding ForecastDays}" 
                                 Padding="10,8"
                                 FontSize="13"/>
                    </StackPanel>

                    <!-- Generate Button -->
                    <Button Grid.Column="3"
                            Content="Generate Forecast"
                            Command="{Binding GenerateForecastCommand}"
                            Width="140"
                            Height="40"
                            Background="#111"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"
                            VerticalAlignment="Bottom"/>
                </Grid>
                
                <!-- Loading Indicator -->
                <Grid Grid.Row="1" Margin="0,12,0,0" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ProgressBar Grid.Column="0" Width="20" Height="20" Margin="0,0,10,0" 
                                 IsIndeterminate="True"/>
                    <TextBlock Grid.Column="1" Text="{Binding LoadingMessage}" VerticalAlignment="Center" FontSize="13"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Results Panel -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Statistics Cards -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Current Price -->
                    <Border Grid.Column="0" Background="White" BorderBrush="#e2e8f0" BorderThickness="1" 
                            CornerRadius="4" Padding="16,12" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Current Price" FontSize="12" Foreground="#666"/>
                            <TextBlock Text="{Binding CurrentPriceText}" FontSize="20" FontWeight="Bold" Foreground="#111"/>
                        </StackPanel>
                    </Border>

                    <!-- Optimal Buying -->
                    <Border Grid.Column="1" Background="White" BorderBrush="#e2e8f0" BorderThickness="1" 
                            CornerRadius="4" Padding="16,12" Margin="4,0">
                        <StackPanel>
                            <TextBlock Text="Optimal Buying Date" FontSize="12" Foreground="#666"/>
                            <TextBlock Text="{Binding OptimalBuyingDateText}" FontSize="16" FontWeight="Bold" Foreground="#16a34a"/>
                            <TextBlock Text="{Binding OptimalBuyingPriceText}" FontSize="13" Foreground="#666"/>
                        </StackPanel>
                    </Border>

                    <!-- Predicted Range -->
                    <Border Grid.Column="2" Background="White" BorderBrush="#e2e8f0" BorderThickness="1" 
                            CornerRadius="4" Padding="16,12" Margin="4,0">
                        <StackPanel>
                            <TextBlock Text="Predicted Range" FontSize="12" Foreground="#666"/>
                            <TextBlock FontSize="16" FontWeight="Bold" Foreground="#2563eb">
                                <Run Text="{Binding PredictedLowText}"/> 
                                <Run Text=" - "/> 
                                <Run Text="{Binding PredictedHighText}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding PredictedAvgText, StringFormat='Avg: {0}'}" FontSize="13" Foreground="#666"/>
                        </StackPanel>
                    </Border>

                    <!-- Recommendation -->
                    <Border Grid.Column="3" Background="White" BorderBrush="#e2e8f0" BorderThickness="1" 
                            CornerRadius="4" Padding="16,12" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Recommendation" FontSize="12" Foreground="#666"/>
                            <TextBlock Text="{Binding OverallRecommendationText}" FontSize="13" FontWeight="SemiBold" 
                                       TextWrapping="Wrap"
                                       Foreground="{Binding RecommendationColor}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Forecast Chart -->
                <Border Grid.Row="1" Background="White" BorderBrush="#e2e8f0" BorderThickness="1" 
                        CornerRadius="4" Padding="16" Margin="0,0,0,20"
                        Visibility="{Binding HasForecasts, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="300"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="Price Forecast Chart" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        
                        <!-- Chart Container - Chart will be created programmatically -->
                        <Border Grid.Row="1" x:Name="ChartContainer" Background="White"/>
                    </Grid>
                </Border>

                <!-- No Forecasts Message -->
                <Border Grid.Row="1" Background="#f9f9f9" BorderBrush="#e2e8f0" BorderThickness="1" 
                        CornerRadius="4" Padding="40" Margin="0,0,0,20"
                        Visibility="{Binding ShowNoForecastsMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="No forecast generated yet" FontSize="16" FontWeight="SemiBold" 
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Select an item and click 'Generate Forecast' to see price predictions" 
                                   FontSize="13" Foreground="#666" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Anomalies Section -->
                <Border Grid.Row="2" Background="White" BorderBrush="#e2e8f0" BorderThickness="1" 
                        CornerRadius="4" Padding="16" Margin="0,0,0,20"
                        Visibility="{Binding HasAnomalies, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="Detected Price Anomalies" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Anomalies}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  Background="White"
                                  RowHeight="48"
                                  CanUserResizeRows="False"
                                  FontSize="13">
                            
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#f8fafb"/>
                                    <Setter Property="Foreground" Value="#666"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#e2e8f0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="12,0"/>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='dd MMM yyyy'}" Width="120"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="150"/>
                                <DataGridTextColumn Header="Price" Binding="{Binding ActualPrice, StringFormat='${0:F2}'}" Width="100"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Forecast Details Table -->
                <Border Grid.Row="3" Background="White" BorderBrush="#e2e8f0" BorderThickness="1" 
                        CornerRadius="4" Padding="16"
                        Visibility="{Binding HasForecasts, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="Daily Forecast Details" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Forecasts}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  Background="White"
                                  RowHeight="40"
                                  CanUserResizeRows="False"
                                  FontSize="13"
                                  MaxHeight="250"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#f8fafb"/>
                                    <Setter Property="Foreground" Value="#666"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#e2e8f0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="12,0"/>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding ForecastDate, StringFormat='dd MMM yyyy'}" Width="120"/>
                                <DataGridTextColumn Header="Predicted" Binding="{Binding PredictedPrice, StringFormat='${0:F2}'}" Width="100"/>
                                <DataGridTextColumn Header="Low" Binding="{Binding LowerBound, StringFormat='${0:F2}'}" Width="80"/>
                                <DataGridTextColumn Header="High" Binding="{Binding UpperBound, StringFormat='${0:F2}'}" Width="80"/>
                                <DataGridTextColumn Header="Trend" Binding="{Binding Trend}" Width="80"/>
                                <DataGridTextColumn Header="Recommendation" Binding="{Binding Recommendation}" Width="140"/>
                                <DataGridTextColumn Header="Reason" Binding="{Binding RecommendationReason}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
