<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">AdvGen PriceComparer</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        @* Public Navigation *@
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="deals">
                <span class="bi bi-tag-fill-nav-menu" aria-hidden="true"></span> Weekly Deals
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="browse">
                <span class="bi bi-search-nav-menu" aria-hidden="true"></span> Browse Items
            </NavLink>
        </div>

        @* Admin Navigation *@
        <AuthorizeView Roles="Admin">
            <Authorized>
                <div class="nav-item px-3 mt-3">
                    <span class="nav-section-title">Administration</span>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin">
                        <span class="bi bi-speedometer2-nav-menu" aria-hidden="true"></span> Dashboard
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/items">
                        <span class="bi bi-box-seam-nav-menu" aria-hidden="true"></span> Items
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/places">
                        <span class="bi bi-shop-nav-menu" aria-hidden="true"></span> Places
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/price-records">
                        <span class="bi bi-currency-dollar-nav-menu" aria-hidden="true"></span> Price Records
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>
</div>

