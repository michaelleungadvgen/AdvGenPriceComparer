@page "/"
@inject IWebDataService WebDataService

<PageTitle>Home - AdvGen PriceComparer</PageTitle>

<div class="container">
    <div class="hero-section text-center py-5 mb-5">
        <h1 class="display-4 fw-bold text-primary">AdvGen PriceComparer</h1>
        <p class="lead text-muted">Compare grocery prices across Australian supermarkets and find the best deals</p>
        <div class="mt-4">
            <a href="deals" class="btn btn-primary btn-lg me-3">
                <i class="bi bi-tag-fill"></i> View Weekly Deals
            </a>
            <a href="browse" class="btn btn-outline-primary btn-lg">
                <i class="bi bi-search"></i> Browse Items
            </a>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted">Loading featured deals...</p>
        </div>
    }
    else if (bestDeals?.Any() == true)
    {
        <div class="featured-deals">
            <h2 class="text-center mb-4">🔥 Featured Deals This Week</h2>
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
                @foreach (var deal in bestDeals.Take(4))
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm deal-card">
                            <div class="card-header bg-success text-white">
                                <span class="badge bg-light text-success">DEAL</span>
                            </div>
                            <div class="card-body">
                                <h5 class="card-title">@deal.Item?.Name</h5>
                                <p class="card-text text-muted small">@deal.Item?.Brand</p>
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span class="h4 mb-0 text-success">$@deal.BestPrice.ToString("F2")</span>
                                    <small class="text-muted">@deal.BestStore?.Name</small>
                                </div>
                            </div>
                            <div class="card-footer bg-transparent">
                                <a href="item/@deal.Item?.Id" class="btn btn-outline-primary btn-sm w-100">View Details</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="text-center mt-4">
                <a href="deals" class="btn btn-outline-success">View All Deals</a>
            </div>
        </div>
    }

    <div class="features-section py-5 mt-5">
        <h2 class="text-center mb-5">How It Works</h2>
        <div class="row row-cols-1 row-cols-md-3 g-4 text-center">
            <div class="col">
                <div class="feature-icon mb-3">
                    <i class="bi bi-search display-4 text-primary"></i>
                </div>
                <h4>Search & Compare</h4>
                <p class="text-muted">Browse thousands of grocery items and compare prices across multiple supermarkets.</p>
            </div>
            <div class="col">
                <div class="feature-icon mb-3">
                    <i class="bi bi-graph-down display-4 text-success"></i>
                </div>
                <h4>Track Prices</h4>
                <p class="text-muted">Monitor price history and identify genuine discounts vs. illusory sales.</p>
            </div>
            <div class="col">
                <div class="feature-icon mb-3">
                    <i class="bi bi-currency-dollar display-4 text-warning"></i>
                </div>
                <h4>Save Money</h4>
                <p class="text-muted">Find the best deals and plan your shopping to maximize savings.</p>
            </div>
        </div>
    </div>
</div>

<style>
    .hero-section {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 1rem;
    }

    .deal-card {
        transition: transform 0.2s ease-in-out;
        border: none;
    }

    .deal-card:hover {
        transform: translateY(-5px);
    }

    .feature-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8f9fa;
        border-radius: 50%;
    }
</style>

@code {
    private List<(Item? Item, decimal BestPrice, Place? BestStore)>? bestDeals;
    private bool isLoading = true;

    protected override void OnInitialized()
    {
        try
        {
            bestDeals = WebDataService.GetBestDeals(4).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading deals: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}
