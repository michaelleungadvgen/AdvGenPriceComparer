@page "/browse"
@inject IWebDataService WebDataService
@inject NavigationManager Navigation

<PageTitle>Browse Items - AdvGen PriceComparer</PageTitle>

<div class="container">
    <h1 class="mb-4">Browse Items</h1>

    @* Search and Filters *@
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" placeholder="Search items..."
                               @bind="searchTerm" @bind:event="oninput" @onkeyup="HandleSearch" />
                        <button class="btn btn-primary" @onclick="ApplyFilters">Search</button>
                    </div>
                </div>
                <div class="col-md-4">
                    <select class="form-select" @bind="selectedCategory">
                        <option value="">All Categories</option>
                        @foreach (var category in categories)
                        {
                            <option value="@category">@category</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary w-100" @onclick="ClearFilters">Clear</button>
                </div>
            </div>
        </div>
    </div>

    @* Results *@
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted">Loading items...</p>
        </div>
    }
    else if (!items.Any())
    {
        <div class="alert alert-info">
            <h4 class="alert-heading">No items found</h4>
            <p>No items match your search criteria. Try adjusting your filters.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var item in items)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm item-card" @onclick="() => ViewItem(item.Id)" style="cursor: pointer;">
                        <div class="card-body">
                            <h5 class="card-title">@item.Name</h5>
                            @if (!string.IsNullOrEmpty(item.Brand))
                            {
                                <p class="card-text text-muted mb-2">@item.Brand</p>
                            }
                            @if (!string.IsNullOrEmpty(item.Category))
                            {
                                <span class="badge bg-secondary">@item.Category</span>
                            }
                        </div>
                        <div class="card-footer bg-transparent text-center">
                            <small class="text-muted">Click for details</small>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* Pagination *@
        @if (totalPages > 1)
        {
            <nav class="mt-4" aria-label="Page navigation">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(!CanGoPrevious ? "disabled" : "")">
                        <button class="page-link" @onclick="PreviousPage" disabled="@(!CanGoPrevious)">Previous</button>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        var pageNumber = i;
                        <li class="page-item @(currentPage == pageNumber ? "active" : "")">
                            <button class="page-link" @onclick="() => GoToPage(pageNumber)">@pageNumber</button>
                        </li>
                    }
                    <li class="page-item @(!CanGoNext ? "disabled" : "")">
                        <button class="page-link" @onclick="NextPage" disabled="@(!CanGoNext)">Next</button>
                    </li>
                </ul>
            </nav>
        }

        <div class="text-center text-muted mt-3">
            Showing @items.Count() of @totalItems items
        </div>
    }
</div>

<style>
    .item-card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
        border: none;
    }

    .item-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
</style>

@code {
    private List<Item> items = new();
    private List<string> categories = new();
    private bool isLoading = true;
    
    private string searchTerm = "";
    private string selectedCategory = "";
    private int currentPage = 1;
    private int pageSize = 18;
    private int totalItems = 0;
    private int totalPages = 0;

    private bool CanGoPrevious => currentPage > 1;
    private bool CanGoNext => currentPage < totalPages;

    protected override void OnInitialized()
    {
        LoadCategories();
        LoadItems();
    }

    private void LoadCategories()
    {
        try
        {
            categories = WebDataService.GetCategories().ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading categories: {ex.Message}");
        }
    }

    private void LoadItems()
    {
        isLoading = true;
        try
        {
            items = WebDataService.GetItems(searchTerm, selectedCategory, currentPage, pageSize).ToList();
            totalItems = WebDataService.GetTotalItemCount(searchTerm, selectedCategory);
            totalPages = (int)Math.Ceiling(totalItems / (double)pageSize);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading items: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            currentPage = 1;
            LoadItems();
        }
    }

    private void ApplyFilters()
    {
        currentPage = 1;
        LoadItems();
    }

    private void ClearFilters()
    {
        searchTerm = "";
        selectedCategory = "";
        currentPage = 1;
        LoadItems();
    }

    private void PreviousPage()
    {
        if (CanGoPrevious)
        {
            currentPage--;
            LoadItems();
        }
    }

    private void NextPage()
    {
        if (CanGoNext)
        {
            currentPage++;
            LoadItems();
        }
    }

    private void GoToPage(int page)
    {
        currentPage = page;
        LoadItems();
    }

    private void ViewItem(string itemId)
    {
        Navigation.NavigateTo($"/item/{itemId}");
    }
}
